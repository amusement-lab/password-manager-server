{
  "name": "password-manager",
  "version": "1.3.0",
  "author": "Dipadana Putu",
  "license": "ISC",
  "description": "Just basic password manager",
  "type": "module",
  "engines": {
    "pnpm": ">=10",
    "node": ">=22.22.2"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "start": "pnpm run build && node build/index.js",
    "build": "rimraf ./build && tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "lint": "oxlint",
    "format": "oxfmt",
    "test:migrate": "dotenv -e .env.test -- prisma migrate reset --force",
    "test:run": "vitest run",
    "test": "concurrently --kill-others --success first \"pnpm test:migrate && dotenv -e .env.test -- tsx src/index.ts\" \"wait-on http://localhost:3030 && pnpm test:run\"",
    "ncu": "ncu"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/superagent": "^8.1.9",
    "@types/swagger-ui-express": "^4.1.8",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "npm-check-updates": "^20.0.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "prisma": "^7.6.0",
    "rimraf": "^6.1.3",
    "superagent": "^10.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  }
}
